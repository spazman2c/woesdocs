{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Woes",
  "description": "Customer-facing documentation and REST API reference for Woes, the API-native developer support platform.",
  "colors": {
    "primary": "#FF7038",
    "light": "#FF7038",
    "dark": "#FF7038"
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#FFF8F2",
      "dark": "#11100F"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "dark"
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:site_name": "Woes Docs",
      "twitter:card": "summary_large_image"
    }
  },
  "search": {
    "prompt": "Search Woes docs, API guides, and endpoint reference..."
  },
  "metadata": {
    "timestamp": true
  },
  "favicon": "/images/woes-mark.png",
  "logo": {
    "light": "/images/woes-wordmark.png",
    "dark": "/images/woes-wordmark.png"
  },
  "redirects": [
    {
      "source": "/api-reference",
      "destination": "/api-reference/overview"
    },
    {
      "source": "/api-authentication",
      "destination": "/api/authentication"
    },
    {
      "source": "/api-conversations",
      "destination": "/api/conversations"
    },
    {
      "source": "/api-issues",
      "destination": "/api/issues"
    },
    {
      "source": "/api-agents",
      "destination": "/api/agents"
    }
  ],
  "navbar": {
    "links": [
      {
        "label": "Docs",
        "href": "https://docs.woes.dev"
      },
      {
        "label": "API Reference",
        "href": "https://docs.woes.dev/api-reference/overview"
      },
      {
        "label": "Trust",
        "href": "https://docs.woes.dev/security/data-privacy"
      },
      {
        "label": "App",
        "href": "https://woes.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://woes.dev"
    }
  },
  "footer": {
    "links": [
      {
        "header": "Product",
        "items": [
          {
            "label": "Quickstart",
            "href": "/quickstart/overview"
          },
          {
            "label": "Support Workflows",
            "href": "/support-workflows/omnichannel-support"
          },
          {
            "label": "Chat Widget",
            "href": "/chat-widget/overview"
          }
        ]
      },
      {
        "header": "Knowledge",
        "items": [
          {
            "label": "Knowledge Base",
            "href": "/knowledge-base/overview"
          },
          {
            "label": "AI Agents",
            "href": "/agents/overview"
          },
          {
            "label": "Analytics",
            "href": "/platform/analytics"
          }
        ]
      },
      {
        "header": "Developer",
        "items": [
          {
            "label": "Developer Overview",
            "href": "/developer/overview"
          },
          {
            "label": "API Reference",
            "href": "/api-reference/overview"
          },
          {
            "label": "Authentication",
            "href": "/api/authentication"
          }
        ]
      },
      {
        "header": "Security",
        "items": [
          {
            "label": "Widget Identity",
            "href": "/security/widget-identity"
          },
          {
            "label": "Data Privacy",
            "href": "/security/data-privacy"
          },
          {
            "label": "Tenant Isolation",
            "href": "/security/tenant-isolation"
          }
        ]
      },
      {
        "header": "Company",
        "items": [
          {
            "label": "Website",
            "href": "https://woes.dev"
          },
          {
            "label": "Blog",
            "href": "https://woes.dev/blog"
          }
        ]
      }
    ]
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "languages": [
        "curl",
        "node",
        "python",
        "javascript"
      ],
      "defaults": "required",
      "prefill": true
    },
    "params": {
      "expanded": "all"
    },
    "url": "full"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart/overview",
              "quickstart/add-context",
              "quickstart/invite-team"
            ]
          },
          {
            "group": "Support workflows",
            "pages": [
              "support-workflows/omnichannel-support",
              "platform/inbox",
              "platform/issues",
              "platform/automations",
              "settings/assignment",
              "settings/surveys",
              "channels/email",
              "channels/discord"
            ]
          },
          {
            "group": "Platform",
            "pages": [
