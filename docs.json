          {
            "group": "Developer",
            "pages": [
              "developer/overview",
              "developer/rest-api",
              "reference/glossary",
              "developer/route-boundaries"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "groups": [
          {
            "group": "API basics",
            "pages": [
              "api-reference/overview",
              "api/overview",
              "api/authentication",
              "api/keys",
              "api/sources",
              "api/definitions",
              "api/usage",
              "api/analytics",
              "api/conversations",
              "api/issues",
              "api/clients",
              "api/agents"
            ]
          },
          {
            "group": "Runtime guides",
            "pages": [
              "reference/routes",
              "api/widget",
              "api/surveys"
            ]
          },
          {
            "group": "Endpoint reference",
            "pages": [
              {
                "group": "Conversations",
                "openapi": "openapi.json",
                "pages": [
                  "GET /api/v1/conversations",
                  "POST /api/v1/conversations",
                  "GET /api/v1/conversations/{conversationId}",
                  "PATCH /api/v1/conversations/{conversationId}",
                  "GET /api/v1/conversations/{conversationId}/messages",
                  "POST /api/v1/conversations/{conversationId}/messages"
                ]
              },
              {
                "group": "Issues",
                "openapi": "openapi.json",
                "pages": [
                  "GET /api/v1/issues",
                  "POST /api/v1/issues",
                  "GET /api/v1/issues/{issueId}",
                  "PATCH /api/v1/issues/{issueId}"
                ]
              },
              {
                "group": "Clients",
                "openapi": "openapi.json",
                "pages": [
                  "GET /api/v1/clients",
                  "POST /api/v1/clients",
                  "GET /api/v1/clients/{clientId}"
                ]
              },
              {
                "group": "Agents",
                "openapi": "openapi.json",
                "pages": [
                  "GET /api/v1/agents",
                  "GET /api/v1/agents/{agentId}"
                ]
              },
              {
                "group": "Sources",
                "openapi": "openapi.json",
                "pages": [
                  "GET /api/v1/sources",
                  "POST /api/v1/sources",
                  "GET /api/v1/sources/{sourceId}",
                  "PATCH /api/v1/sources/{sourceId}",
                  "DELETE /api/v1/sources/{sourceId}",
                  "POST /api/v1/sources/{sourceId}/rescan"
                ]
              },
              {
                "group": "Definitions",
                "openapi": "openapi.json",
                "pages": [
                  "GET /api/v1/tags",
                  "GET /api/v1/statuses",
                  "GET /api/v1/priorities",
                  "GET /api/v1/custom-fields"
                ]
              },
              {
                "group": "Usage",
                "openapi": "openapi.json",
                "pages": [
                  "GET /api/v1/usage",
                  "GET /api/v1/usage/api-keys"
                ]
              },
              {
                "group": "Analytics",
                "openapi": "openapi.json",
                "pages": [
                  "GET /api/v1/analytics"
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
