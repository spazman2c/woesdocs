              "customer-portal/access-control"
            ]
          },
          {
            "group": "Chat widget",
            "pages": [
              "chat-widget/overview",
              "channels/live-chat",
              "quickstart/install-widget",
              "quickstart/install-widget-mintlify",
              "chat-widget/javascript-api",
              "chat-widget/identity-verification"
            ]
          },
          {
            "group": "Account intelligence",
            "pages": [
              "account-intelligence/overview",
              "platform/clients",
              "account-intelligence/presence"
            ]
          },
          {
            "group": "Product intelligence",
            "pages": [
              "product-intelligence/overview",
              "product-intelligence/feature-requests",
              "product-intelligence/closing-loop"
            ]
          },
          {
            "group": "Reporting & analytics",
            "pages": [
