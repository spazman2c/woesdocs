{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Woes",
  "description": "Customer-facing documentation and REST API reference for Woes, the API-native developer support platform.",
  "colors": {
    "primary": "#FF7038",
    "light": "#FF7038",
    "dark": "#FF7038"
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#FFF8F2",
      "dark": "#11100F"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "dark"
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:site_name": "Woes Docs",
      "twitter:card": "summary_large_image"
    }
  },
  "search": {
    "prompt": "Search Woes docs, API guides, and endpoint reference..."
  },
  "metadata": {
    "timestamp": true
  },
  "favicon": "/images/woes-mark.png",
  "logo": {
    "light": "/images/woes-wordmark.png",
    "dark": "/images/woes-wordmark.png"
  },
  "redirects": [
    {
      "source": "/api-reference",
      "destination": "/api-reference/overview"
    },
    {
      "source": "/api-authentication",
      "destination": "/api/authentication"
    },
    {
      "source": "/api-conversations",
      "destination": "/api/conversations"
    },
    {
      "source": "/api-issues",
      "destination": "/api/issues"
    },
    {
      "source": "/api-agents",
      "destination": "/api/agents"
    }
  ],
  "navbar": {
    "links": [
      {
        "label": "Docs",
        "href": "https://docs.woes.dev"
      },
      {
        "label": "API Reference",
        "href": "https://docs.woes.dev/api-reference/overview"
      },
      {
        "label": "Trust",
        "href": "https://docs.woes.dev/security/data-privacy"
      },
      {
        "label": "App",
        "href": "https://woes.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://woes.dev"
    }
  },
  "footer": {
    "links": [
      {
        "header": "Product",
        "items": [
          {
            "label": "Quickstart",
            "href": "/quickstart/overview"
          },
          {
            "label": "Inbox",
            "href": "/platform/inbox"
          },
          {
            "label": "Agents",
            "href": "/agents/overview"
          }
        ]
      },
      {
        "header": "API",
        "items": [
          {
            "label": "API Reference",
            "href": "/api-reference/overview"
          },
          {
            "label": "Authentication",
            "href": "/api/authentication"
          },
          {
            "label": "Conversations",
            "href": "/api/conversations"
          }
        ]
      },
      {
        "header": "Security",
        "items": [
          {
            "label": "Widget Identity",
            "href": "/security/widget-identity"
          },
          {
            "label": "Data Privacy",
            "href": "/security/data-privacy"
          },
          {
            "label": "Tenant Isolation",
            "href": "/security/tenant-isolation"
          }
        ]
      },
      {
        "header": "Company",
        "items": [
          {
            "label": "Website",
            "href": "https://woes.dev"
          },
          {
            "label": "Blog",
            "href": "https://woes.dev/blog"
          }
        ]
      }
    ]
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "languages": ["curl", "node", "python", "javascript"],
      "defaults": "required",
      "prefill": true
    },
    "params": {
      "expanded": "all"
    },
    "url": "full"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "book-open",
        "groups": [
          {
            "group": "Start here",
            "pages": [
              "index",
              "quickstart/overview",
              "quickstart/add-context",
              "quickstart/install-widget",
              "quickstart/invite-team"
            ]
          },
          {
            "group": "Core platform",
            "pages": [
              "platform/inbox",
              "platform/issues",
              "platform/clients",
              "platform/client-portal",
              "platform/automations",
              "platform/analytics"
            ]
          },
          {
            "group": "Channels",
            "pages": [
              "channels/live-chat",
              "api/widget",
              "channels/email",
              "channels/discord"
            ]
          },
          {
            "group": "API context",
            "pages": [
              "context/sources",
              "context/auth-testing",
              "context/github"
            ]
          },
          {
            "group": "Agents",
            "pages": [
              "agents/overview",
              "agents/create-agents",
              "agents/context-learning",
              "agents/routing-widget"
            ]
          },
          {
            "group": "Settings",
            "pages": [
              "settings/overview",
              "settings/keys",
              "settings/surveys",
              "api/surveys",
              "settings/users-permissions",
              "settings/notifications",
              "settings/data-macros"
            ]
          },
          {
            "group": "Security",
            "pages": [
              "security/widget-identity",
              "security/data-privacy",
              "security/tenant-isolation"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/routes",
              "reference/glossary",
              "reference/troubleshooting"
            ]
          },
          {
            "group": "REST API guides",
            "pages": [
              "api/overview",
              "api/authentication",
              "api/keys",
              "api/conversations",
              "api/issues",
              "api/clients",
              "api/agents"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "groups": [
          {
            "group": "API basics",
            "pages": [
              "api-reference/overview",
              "api/authentication",
              "api/keys"
            ]
          },
          {
            "group": "Endpoint reference",
            "pages": [
              {
                "group": "Conversations",
                "openapi": "openapi.json",
                "pages": [
                  "GET /api/v1/conversations",
                  "POST /api/v1/conversations",
                  "GET /api/v1/conversations/{conversationId}",
                  "PATCH /api/v1/conversations/{conversationId}",
                  "GET /api/v1/conversations/{conversationId}/messages",
                  "POST /api/v1/conversations/{conversationId}/messages"
                ]
              },
              {
                "group": "Issues",
                "openapi": "openapi.json",
                "pages": [
                  "GET /api/v1/issues",
                  "POST /api/v1/issues",
                  "GET /api/v1/issues/{issueId}",
                  "PATCH /api/v1/issues/{issueId}"
                ]
              },
              {
                "group": "Clients",
                "openapi": "openapi.json",
                "pages": [
                  "GET /api/v1/clients",
                  "GET /api/v1/clients/{clientId}"
                ]
              },
              {
                "group": "Agents",
                "openapi": "openapi.json",
                "pages": [
                  "GET /api/v1/agents",
                  "GET /api/v1/agents/{agentId}"
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
