{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Woes",
  "colors": {
    "primary": "#FF7038",
    "light": "#FFF1E8",
    "dark": "#202020"
  },
  "favicon": "/images/woes-mark.png",
  "logo": {
    "light": "/images/woes-wordmark.png",
    "dark": "/images/woes-wordmark.png"
  },
  "redirects": [
    {
      "source": "/api-reference",
      "destination": "/api-reference/overview"
    },
    {
      "source": "/api-authentication",
      "destination": "/api/authentication"
    },
    {
      "source": "/api-conversations",
      "destination": "/api/conversations"
    },
    {
      "source": "/api-issues",
      "destination": "/api/issues"
    },
    {
      "source": "/api-agents",
      "destination": "/api/agents"
    }
  ],
  "navbar": {
    "links": [
      {
        "label": "App",
        "href": "https://woes.dev"
      }
    ]
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "languages": ["curl", "node", "python", "javascript"],
      "defaults": "required",
      "prefill": true
    },
    "params": {
      "expanded": "all"
    },
    "url": "full"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "book-open",
        "groups": [
          {
            "group": "Start Here",
            "pages": [
              "index",
              "quickstart/overview",
              "quickstart/add-context",
              "quickstart/install-widget",
              "quickstart/invite-team"
            ]
          },
          {
            "group": "Core Platform",
            "pages": [
              "platform/inbox",
              "platform/issues",
              "platform/clients",
              "platform/client-portal",
              "platform/automations",
              "platform/analytics"
            ]
          },
          {
            "group": "Channels",
            "pages": [
              "channels/live-chat",
              "channels/email",
              "channels/discord"
            ]
          },
          {
            "group": "API Context",
            "pages": [
              "context/sources",
              "context/auth-testing",
              "context/github"
            ]
          },
          {
            "group": "Agents",
            "pages": [
              "agents/overview",
              "agents/create-agents",
              "agents/context-learning",
              "agents/routing-widget"
            ]
          },
          {
            "group": "Settings",
            "pages": [
              "settings/overview",
              "settings/keys",
              "settings/surveys",
              "settings/users-permissions",
              "settings/notifications",
              "settings/data-macros"
            ]
          },
          {
            "group": "Security",
            "pages": [
              "security/widget-identity",
              "security/data-privacy",
              "security/tenant-isolation"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/routes",
              "reference/glossary",
              "reference/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview",
              "api/overview",
              "api/authentication",
              "api/keys"
            ]
          },
          {
            "group": "REST API Guides",
            "pages": [
              "api/conversations",
              "api/issues",
              "api/clients",
              "api/agents"
            ]
          },
          {
            "group": "Conversation Endpoints",
            "openapi": "openapi.json",
            "pages": [
              "GET /api/v1/conversations",
              "POST /api/v1/conversations",
              "GET /api/v1/conversations/{conversationId}",
              "PATCH /api/v1/conversations/{conversationId}",
              "GET /api/v1/conversations/{conversationId}/messages",
              "POST /api/v1/conversations/{conversationId}/messages"
            ]
          },
          {
            "group": "Issue Endpoints",
            "openapi": "openapi.json",
            "pages": [
              "GET /api/v1/issues",
              "POST /api/v1/issues",
              "GET /api/v1/issues/{issueId}",
              "PATCH /api/v1/issues/{issueId}"
            ]
          },
          {
            "group": "Client Endpoints",
            "openapi": "openapi.json",
            "pages": [
              "GET /api/v1/clients",
              "GET /api/v1/clients/{clientId}"
            ]
          },
          {
            "group": "Agent Endpoints",
            "openapi": "openapi.json",
            "pages": [
              "GET /api/v1/agents",
              "GET /api/v1/agents/{agentId}"
            ]
          },
          {
            "group": "Widget & Surveys",
            "pages": [
              "api/widget",
              "api/surveys"
            ]
          }
        ]
      }
    ]
  }
}
